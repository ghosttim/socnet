{
  "id": null,
  "uid": "postgres-replication",
  "title": "PostgreSQL Replication Monitoring",
  "timezone": "browser",
  "schemaVersion": 36,
  "version": 2,
  "refresh": "5s",
  "panels": [

    {
      "type": "stat",
      "title": "Rows inserted MASTER",
      "gridPos": { "x": 0, "y": 0, "w": 8, "h": 6 },
      "targets": [
        {
          "expr": "pg_stat_user_tables_n_tup_ins{instance=\"postgres-exporter-master:9187\",relname=\"users\"}",
          "refId": "A"
        }
      ]
    },

    {
      "type": "stat",
      "title": "Rows in table REPLICA1",
      "gridPos": { "x": 8, "y": 0, "w": 8, "h": 6 },
      "targets": [
        {
          "expr": "users_count_value{instance=\"postgres-exporter-replica1:9187\"}",
          "refId": "A"
        }
      ]
    },

    {
      "type": "stat",
      "title": "Rows in table REPLICA2",
      "gridPos": { "x": 16, "y": 0, "w": 8, "h": 6 },
      "targets": [
        {
          "expr": "users_count_value{instance=\"postgres-exporter-replica2:9187\"}",
          "refId": "A"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "Insert Rate (rows/sec)",
      "gridPos": { "x": 0, "y": 6, "w": 24, "h": 8 },
      "targets": [
        {
          "expr": "rate(pg_stat_user_tables_n_tup_ins{relname=\"users\"}[1m])",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "Replication Difference (Master vs Replica)",
      "gridPos": { "x": 0, "y": 14, "w": 24, "h": 8 },
      "targets": [
        {
          "expr": "pg_stat_user_tables_n_tup_ins{instance=\"postgres-exporter-master:9187\",relname=\"users\"} - users_count_value{instance=\"postgres-exporter-replica1:9187\"}",
          "legendFormat": "Master - Replica1",
          "refId": "A"
        },
        {
          "expr": "pg_stat_user_tables_n_tup_ins{instance=\"postgres-exporter-master:9187\",relname=\"users\"} - users_count_value{instance=\"postgres-exporter-replica2:9187\"}",
          "legendFormat": "Master - Replica2",
          "refId": "B"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "Transaction commits",
      "gridPos": { "x": 0, "y": 22, "w": 24, "h": 8 },
      "targets": [
        {
          "expr": "rate(pg_stat_database_xact_commit[1m])",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    }

  ]
}